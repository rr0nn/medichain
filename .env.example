# Copy this file to .env.local and replace the placeholder values with real secrets.

# App database
DATABASE_URL="postgresql://medichain:medichain@localhost:5432/medichain"

# AI provider keys
# Set at least one provider key below for the app's AI features to work.
# Additional provider keys are optional and make more models available in the selector.
GOOGLE_GENERATIVE_AI_API_KEY="your_google_ai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"

# Neo4j connection
NEO4J_URI="neo4j+s://your-instance.databases.neo4j.io"
NEO4J_USERNAME="your_neo4j_username"
NEO4J_PASSWORD="your_neo4j_password"
NEO4J_DATABASE="neo4j"

# Optional Neo4j Aura metadata
AURA_INSTANCEID="your_aura_instance_id"
AURA_INSTANCENAME="your_aura_instance_name"
